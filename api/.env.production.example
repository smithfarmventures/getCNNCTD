# Production env vars for the Railway deployment.
# Set these in the Railway dashboard: Service → Variables.
# Do NOT commit the filled-in version.

# Neon (or Railway) Postgres connection string.
# For Neon: grab the "Pooled connection" string from the Neon console.
DATABASE_URL=

# Long random secret used to sign JWTs. Generate a fresh one per environment.
# Generate locally with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Allowed CORS origin for the Vercel web app.
# Example: https://getcnnctd.com (or https://cnnctd.vercel.app for preview)
CORS_ORIGIN=

# Railway sets PORT automatically, but you can override locally.
# PORT=3000
