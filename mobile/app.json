{
  "expo": {
    "name": "CNNCTD",
    "slug": "cnnctd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#1C2333"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cnnctd.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1C2333"
      },
      "package": "com.cnnctd.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "cnnctd"
  }
}
